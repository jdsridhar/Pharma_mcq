# Copy to `.env` and adjust. Consumed by docker-compose AND the API (@pharmacy/config).
# ───────────────────────── Core ─────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ───────────────────────── API ──────────────────────────
API_PORT=4000
API_GLOBAL_PREFIX=api
APP_WEB_URL=http://localhost:3000

# ─────────────────────── Postgres ───────────────────────
POSTGRES_USER=pharmacy
POSTGRES_PASSWORD=pharmacy
POSTGRES_DB=pharmacy_mcq
POSTGRES_PORT=5432
# Host runs use localhost; docker-compose overrides host to "postgres" for the api service.
DATABASE_URL=postgresql://pharmacy:pharmacy@localhost:5432/pharmacy_mcq?schema=public

# ──────────────────────── Redis ─────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ───────────────────────── Auth ─────────────────────────
# In production these MUST be >=32 random chars (enforced by @pharmacy/config).
JWT_ACCESS_SECRET=dev-access-secret-0001-not-for-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-0002-not-for-production
JWT_REFRESH_TTL=30d
BCRYPT_ROUNDS=12

# ─────────────────── Rate limiting ──────────────────────
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=120

# ───────────── Object storage (MinIO in dev) ────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=pharmacy-media
S3_FORCE_PATH_STYLE=true

# ───────────────── Mail (Mailpit in dev) ────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Pharmacy MCQ <no-reply@pharmacy-mcq.local>

# ───────────── Payments (Razorpay; §7-C) ────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ──────────────────── Tenancy (§7-A) ────────────────────
DEFAULT_ORGANIZATION_SLUG=default
