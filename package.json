{
  "name": "pharmacy-mcq-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise Pharmacy MCQ Platform — modular monorepo (NestJS + Next.js).",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "db:generate": "pnpm --filter @pharmacy/api db:generate",
    "db:migrate": "pnpm --filter @pharmacy/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @pharmacy/api db:migrate:deploy",
    "db:seed": "pnpm --filter @pharmacy/api db:seed",
    "db:studio": "pnpm --filter @pharmacy/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
