{
  "name": "@pharmacy/api",
  "version": "0.1.0",
  "private": true,
  "description": "Pharmacy MCQ Platform — NestJS API (modular monolith).",
  "scripts": {
    "build": "nest build",
    "dev": "dotenv -e ../../.env -- nest start --watch",
    "start": "dotenv -e ../../.env -- node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "dotenv -e ../../.env -- jest --config ./test/jest-e2e.json --runInBand",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:sql": "dotenv -e ../../.env -- prisma db execute --file prisma/sql/search_and_partitioning.sql --schema prisma/schema.prisma",
    "db:rls": "dotenv -e ../../.env -- prisma db execute --file prisma/sql/rls.sql --schema prisma/schema.prisma",
    "clean": "rimraf dist .turbo tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.2.3",
    "@pharmacy/config": "workspace:*",
    "@pharmacy/contracts": "workspace:*",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.13.0",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "nestjs-pino": "^4.1.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@pharmacy/eslint-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/../tsconfig.json" }]
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@pharmacy/contracts$": "<rootDir>/../../../packages/contracts/src/index.ts",
      "^@pharmacy/config$": "<rootDir>/../../../packages/config/src/index.ts"
    }
  }
}
